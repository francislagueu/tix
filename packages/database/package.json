{
  "name": "@tix/database",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "typeorm migration:generate -d src/data-source.ts src/migrations/auto",
    "db:migrate": "typeorm migration:run -d src/data-source.ts",
    "db:revert": "typeorm migration:revert -d src/data-source.ts",
    "db:seed": "tsx src/seeds/seed.ts"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "class-validator": "^0.15.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2"
  }
}
