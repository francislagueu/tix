# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tix_platform
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tix_platform

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Application
NODE_ENV=development
API_PORT=3000
FRONTEND_URL=http://localhost:3001
MOBILE_APP_SCHEME=tix

# Payments - Mobile Money
MTN_MOMO_API_KEY=dev_mtn_key
MTN_MOMO_SECRET=dev_mtn_secret
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
ORANGE_MONEY_API_KEY=dev_orange_key
ORANGE_MONEY_SECRET=dev_orange_secret
WAVE_API_KEY=dev_wave_key
WAVE_SECRET=dev_wave_secret

# Payments - Cards
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=2.5
RESERVATION_PAYMENT_HOURS_BEFORE=24
SAME_DAY_PAYMENT_HOURS_BEFORE=4
NO_RESERVATION_HOURS_BEFORE=2

# AI/ML Services
OPENAI_API_KEY=your_openai_api_key
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx

# Email & SMS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# File Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=tix-platform-uploads

# Maps & Location
MAPBOX_ACCESS_TOKEN=your_mapbox_token
GOOGLE_MAPS_API_KEY=your_google_maps_key